<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xujc.mvcpro.mapper.TestQuestionMapper">
    
    <insert id="insert" parameterType="com.xujc.mvcpro.pojo.TestQuestion">
        INSERT INTO test_question (test_id, question_id, score)
        VALUES (#{testId}, #{questionId}, #{score})
    </insert>
    
    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO test_question (test_id, question_id, score)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.testId}, #{item.questionId}, #{item.score})
        </foreach>
    </insert>
    
    <delete id="deleteById" parameterType="Long">
        DELETE FROM test_question WHERE id = #{id}
    </delete>
    
    <delete id="deleteByTestId" parameterType="Long">
        DELETE FROM test_question WHERE test_id = #{testId}
    </delete>
    
    <select id="selectByTestId" parameterType="Long" resultType="com.xujc.mvcpro.pojo.TestQuestion">
        SELECT * FROM test_question WHERE test_id = #{testId}
    </select>
    
    <select id="selectByTestIds" resultType="com.xujc.mvcpro.pojo.TestQuestion">
        SELECT * FROM test_question WHERE test_id IN
        <foreach collection="testIds" item="testId" open="(" separator="," close=")">
            #{testId}
        </foreach>
    </select>
</mapper>
